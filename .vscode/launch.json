{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Debug API (https profile)",
            "type": "coreclr",
            "request": "launch",
            "preLaunchTask": "build-api",
            "program": "${workspaceFolder}/src/Fiap.Soat.Hackaton.FileService.Api/bin/Debug/net10.0/Fiap.Soat.Hackaton.FileService.Api.dll",
            "args": [],
            "cwd": "${workspaceFolder}/src/Fiap.Soat.Hackaton.FileService.Api",
            "stopAtEntry": false,
            "serverReadyAction": {
                "action": "openExternally",
                "pattern": "\\bNow listening on:\\s+(https?://\\S+)"
            },
            "env": {
                "ASPNETCORE_ENVIRONMENT": "Development",
                "ASPNETCORE_URLS": "https://localhost:7005;http://localhost:5194"
            }
        }
    ]
}
